# LLM Provider: "ollama", "xai", "zai", "groq", or "deepseek"
LLM_PROVIDER=ollama

# Ollama configuration (for LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=mistral

# xAI API configuration (for LLM_PROVIDER=xai)
XAI_API_KEY=your-xai-api-key-here
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-beta

# z.AI API configuration (for LLM_PROVIDER=zai)
ZAI_API_KEY=your-zai-api-key-here
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_MODEL=glm-4.7

# Groq API configuration (for LLM_PROVIDER=groq)
GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama3-70b-8192

# DeepSeek API configuration (for LLM_PROVIDER=deepseek)
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Default location (Monheim 40789)
DEFAULT_LOCATION=Monheim 40789

# SQLite DB path (default: project/data/events.db)
# DB_PATH=

