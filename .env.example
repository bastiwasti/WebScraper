# Ollama server (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model name (run: ollama pull mistral)
LLM_MODEL=mistral

# Default location (Monheim 40789)
DEFAULT_LOCATION=Monheim 40789

# Focus on family/children events (true/false)
FAMILY_FOCUS=true

# SQLite DB path (default: project/data/events.db)
# DB_PATH=
