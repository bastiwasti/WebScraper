# LLM Provider: "deepseek" (default) or "ollama"
LLM_PROVIDER=deepseek

# Ollama configuration (for LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=gemma2:2b

# DeepSeek API configuration (for LLM_PROVIDER=deepseek) - FREE!
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Default location (Monheim 40789)
DEFAULT_LOCATION=Monheim 40789

# PostgreSQL connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=vmpostgres
PG_USER=webscraper
PG_PASSWORD=your-webscraper-db-password-here
PG_SCHEMA=webscraper

# Google Places API (optional)
# GOOGLE_PLACES_API_KEY=
